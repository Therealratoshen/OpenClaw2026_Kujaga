# Kujaga Environment Variables

# Server
PORT=3000
LOG_LEVEL=info

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# MiniMax AI (for PDUPA letter generation)
MINIMAX_API_KEY=your_minimax_api_key

# DOKU Payment (sandbox)
DOKU_MCP_URL=https://api-sandbox.doku.com/doku-mcp-server/mcp
DOKU_CLIENT_ID=BRN-xxxxx
DOKU_AUTHORIZATION=Basic base64_encoded_api_key

# Supabase (optional, for database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key